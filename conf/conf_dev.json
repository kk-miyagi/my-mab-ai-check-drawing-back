{
    "APP_STATUS":{
       "expire": 86400 
    },
    "LOGGER":{
	"logger_name": "app_main",
	"log_level": "DEBUG",
	"log_backup_count": 60,
	"log_file_name": "./logs/app_main.log", 
	"log_interval": 1,
	"log_when": "D",
	"log_encoding": "shift_jis"
    },
    "BATCH_LOGGER":{
	"logger_name": "app_batch",
	"log_level": "DEBUG",
	"log_backup_count": 60,
	"log_file_name": "./logs/app_batch.log", 
	"log_interval": 1,
	"log_when": "D",
	"log_encoding": "utf-8"
    },
    "ROUTING": {
	"epic-init": [],
	"issue/operation-id": [],
	"multi-fileupload": [],
	"check-status": [],
	"demo-create-label": []
    },
    "BACKEND_TASKS": {
	"create-label_batch-create-label": "bash ./shell/create_label.sh",
	"update-label_batch-update-label": "bash ./shell/update_label.sh"
    }
}
