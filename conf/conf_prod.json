{
    "APP_STATUS":{
       "expire": 1209600
    },
    "REDIS":{
	"host": "",
	"port": 6380,
	"password": "",
	"ssl": true
    },
    "LOGGER":{
	"logger_name": "app_main",
	"log_level": "INFO",
	"log_backup_count": 60,
	"log_file_name": "./logs/app_main.log", 
	"log_interval": 1,
	"log_when": "D",
	"log_encoding": "utf-8"
    },
    "BATCH_LOGGER":{
	"logger_name": "app_batch",
	"log_level": "INFO",
	"log_backup_count": 60,
	"log_file_name": "./logs/app_batch.log", 
	"log_interval": 1,
	"log_when": "D",
	"log_encoding": "utf-8"
    },
    "ROUTING": {
	"epic-init": [],
	"issue/operation-id": [],
	"multi-fileupload": [],
	"check-status": [],
	"demo-create-label": []
    },
    "BACKEND_TASKS": {
	"create-label_batch-create-label": "bash ./shell/create_label.sh",
	"update-label_batch-update-label": "bash ./shell/update_label.sh",
	"drawing-review_batch-drawing-review": "bash ./shell/drawing_review.sh",
	"drawing-compare_batch-drawing-compare": "bash ./shell/drawing_compare.sh"
    },
    "DATABASE": {
	"db-name": "check-drawing.db",
	"create-user-table": "CREATE TABLE IF NOT EXISTS users (id INTEGER PRIMARY KEY AUTOINCREMENT, username TEXT UNIQUE NOT NULL, password_hash TEXT NOT NULL)",
	"insert-user-table": "INSERT INTO users (username, password_hash) VALUES (?, ?)",
	"get-user-table": "SELECT password_hash FROM users WHERE username = ?"
    },
    "LOGIN": {
	"secret-key": "check-drawing",
	"algorithms": "HS256",
	"expire-min": 1440,
	"secure-cookie": true
    },
    "DATA_RETENTION": {
        "api_key": "change-me-prod",
        "source_dirs": [
            "./multi-fileupload",
            "./create-label-responce",
            "./drawing-compare-responce",
            "./drawing-highlight-responce",
            "./drawing-review-responce",
            "./update-label-response"
        ],
        "deletion_dir": "./to-delete"
    }
}
